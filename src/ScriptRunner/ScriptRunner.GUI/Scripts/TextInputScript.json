{
  "$schema": "../../../../schema/v1/ScriptRunnerSchema.json",
  "actions": [
    {
      "name": "Ping",
      "description": "Execute ping command",
      "command": "ping {address} -t",
      "params": [
        {
          "name": "address",
          "prompt": "text",
          "default": "www.wp.pl"
        }
      ],
      "predefinedArgumentSets": [
        {
          "description": "Ping Twitter",
          "arguments": {
            "address": "wwww.twitter.com"
          }
        },
        {
          "description": "Ping Github",
          "arguments": {
            "address": "wwww.github.com"
          }
        }
      ]
    },
    {
      "name": "FallbackToExisting Demo",
      "description": "Demonstrates the fallbackToExisting feature",
      "command": "echo Server: {server}, Port: {port}, Username: {username}",
      "params": [
        {
          "name": "server",
          "description": "Server address",
          "prompt": "text",
          "default": "localhost"
        },
        {
          "name": "port",
          "description": "Port number",
          "prompt": "text",
          "default": ""
        },
        {
          "name": "username",
          "description": "Username",
          "prompt": "text",
          "default": ""
        }
      ],
      "predefinedArgumentSets": [
        {
          "description": "Production Server Only",
          "fallbackToDefault": true,
          "fallbackToExisting": true,
          "arguments": {
            "server": "prod.example.com"
          }
        },
        {
          "description": "Dev Server (clears other fields)",
          "fallbackToDefault": true,
          "arguments": {
            "server": "dev.example.com"
          }
        },
        {
          "description": "Full Production Config",
          "fallbackToDefault": true,
          "arguments": {
            "server": "prod.example.com",
            "port": "443",
            "username": "admin"
          }
        }
      ]
    },
    {
      "name": "AllControlsTest",
      "description": "Demo of all available controls",
      "command": "pwsh.exe -NoProfile -Command Write-Host '{p1} {p2} {p3} {p4} {p5} {p6} {p7} {p8} {p9} {p10} {p11} {p12}'",
      "params": [
        {
          "name": "p1",
          "description": "Text parameter",
          "default": "v1",
          "prompt": "text"
        },
        {
          "name": "p2",
          "description": "Multiline Text parameter",
          "default": "Line 1\r\n Line 2",
          "prompt": "multilineText"
        },
        {
          "name": "p3",
          "description": "Multiline JSON",
          "default": "Line 1\r\n Line 2",
          "prompt": "multilineText",
          "promptSettings": {
            "syntax": "json"
          }
        },
        {
          "name": "p31",
          "description": "Multiline C# code",
          "default": "Line 1\r\n Line 2",
          "prompt": "multilineText",
          "promptSettings": {
            "syntax": "cs"
          }
        },
        {
          "name": "p32",
          "description": "SQL code",
          "details": "This is a multiline sql code with sqlserver syntax\r\n but postgres might be supported as well",
          "default": "Line 1\r\n Line 2",
          "prompt": "multilineText",
          "promptSettings": {
            "syntax": "sql"
          }
        },
        {
          "name": "p4",
          "description": "Fil Content",
          "default": "using System;\r\n\r\nclass Program {\r\n    static void Main() {\r\n        Console.WriteLine(\"Hello, World!\");\r\n    }\r\n}",
          "prompt": "fileContent",
          "promptSettings": {
            "extension": "cs",
            "templateText": "using System;\r\n\r\nclass Program {\r\n    static void Main() {\r\n        Console.WriteLine(\"Hello, World!\");\r\n    }\r\n}"
          }
        },
        {
          "name": "p5",
          "description": "Checkbox parameter",
          "default": "checked",
          "prompt": "checkbox",
          "promptSettings":{
            "checkedValue": "checked",
            "uncheckedValue": "unchecked"
          }
        },
        {
          "name": "p6",
          "description": "Date parameter",
          "default": "2022-05-03",
          "prompt": "datePicker",
          "promptSettings":{
            "format":"yyyy-MM-dd"
          }
        },
        {
          "name": "p7",
          "description": "Year-Month parameter",
          "default": "2022-05",
          "prompt": "datePicker",
          "promptSettings":{
            "format":"yyyy-MM",
            "dayVisible":"false"
          }
        },
        {
          "name": "p8",
          "description": "Dropdown parameter",
          "default": "val3",
          "prompt": "dropdown",
          "promptSettings":{
            "options":"val1,val2,val3,val4"
          }
        },
        {
          "name": "p9",
          "description": "MultiSelect parameter",
          "default": "val3,val4",
          "prompt": "multiSelect",
          "promptSettings":{
            "options":"val1,val2,val3,val4",
            "delimiter":","
          }
        },
        {
          "name": "p10",
          "description": "Password parameter",
          "default": "secret",
          "prompt": "password"
        },
        {
          "name": "p11",
          "description": "File parameter",
          "default": "c:\\Windows\\explorer.exe",
          "prompt": "filePicker"
        },
        {
          "name": "p12",
          "description": "Directory parameter",
          "default": "c:\\Windows\\",
          "prompt": "directoryPicker"
        },
        {
          "name": "p14",
          "description": "Numeric parameter",
          "default": "7",
          "prompt": "numeric",
          "promptSettings": {
            "min": "5",
            "max": "15",
            "step": "2"
          }
        },
        {
          "name": "p15",
          "description": "Time parameter",
          "default": "7:30",
          "prompt": "timePicker",
          "promptSettings": {
            "format": "hh\\:mm"
          }
        }
      ]
    }
  ]
}