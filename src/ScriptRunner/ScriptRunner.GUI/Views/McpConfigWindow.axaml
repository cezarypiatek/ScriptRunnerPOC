<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ScriptRunner.GUI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="800"
        Width="820" MinHeight="500" Height="800"
        x:Class="ScriptRunner.GUI.Views.McpConfigWindow"
        x:Name="Root"
        Title="MCP Server Configuration"
        Icon="/Assets/avalonia-logo.ico"
        FontFamily="Segoe UI Variable"
        WindowStartupLocation="CenterOwner"
        Background="#212222">

    <Design.DataContext>
        <vm:McpConfigWindowViewModel />
    </Design.DataContext>

        <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Enable / Disable toggle -->
        <Border Grid.Row="0" Padding="12" Margin="0,0,0,12" BorderThickness="1" CornerRadius="4" BorderBrush="#85DFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚙" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontSize="14" FontWeight="Bold" Text="MCP HTTP Server"/>
                    <TextBlock FontSize="11" Foreground="#858585" TextWrapping="Wrap" Text="Expose loaded actions as Model Context Protocol tools over HTTP on http://127.0.0.1"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,20,0" Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Port:" FontSize="13"/>
                    <NumericUpDown Value="{Binding Port}"
                                   Minimum="1024" Maximum="65535"
                                   Increment="1"
                                   FormatString="0"
                                   Width="100"
                                   TextAlignment="Right"
                                   ShowButtonSpinner="False"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                </StackPanel>

                <ToggleSwitch Grid.Column="3" IsChecked="{Binding Enabled}" VerticalAlignment="Center" OnContent="" OffContent=""/>
            </Grid>
        </Border>

        <!-- Master "expose all actions" toggle -->
        <Border Grid.Row="1" Padding="10" Margin="0,0,0,8" BorderThickness="1" CornerRadius="4" BorderBrush="#60A5FA">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="Expose all actions"/>
                    <TextBlock FontSize="11" Foreground="#858585" TextWrapping="Wrap" Text="When off, only the individually enabled actions below are exposed"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding ExposeAllActions}" VerticalAlignment="Center" OnContent="" OffContent=""/>
            </Grid>
        </Border>

        <!-- Master "return output for all" toggle -->
        <Border Grid.Row="2" Padding="10" Margin="0,0,0,8" BorderThickness="1" CornerRadius="4" BorderBrush="#C084FC">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="Return output for all actions"/>
                    <TextBlock FontSize="11" Foreground="#858585" TextWrapping="Wrap" Text="When off, only individually configured actions return their full output"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding ExposeOutputForAllActions}" VerticalAlignment="Center" OnContent="" OffContent=""/>
            </Grid>
        </Border>

        <!-- Master "brave mode for all" toggle -->
        <Border Grid.Row="3" Padding="10" Margin="0,0,0,8" BorderThickness="1" CornerRadius="4" BorderBrush="#FF8C00">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="Brave mode for all actions"/>
                    <TextBlock FontSize="11" Foreground="#858585" TextWrapping="Wrap" Text="When off, MCP-populated parameters are highlighted and execution requires manual confirmation"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding BraveModeForAllActions}" VerticalAlignment="Center" OnContent="" OffContent=""/>
            </Grid>
        </Border>

        <!-- Master "fire and forget for all" toggle -->
        <Border Grid.Row="4" Padding="10" Margin="0,0,0,8" BorderThickness="1" CornerRadius="4" BorderBrush="#4CAF50">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="Fire &amp; forget for all actions"/>
                    <TextBlock FontSize="11" Foreground="#858585" TextWrapping="Wrap" Text="When on, the MCP call returns after 3 s if the job hasn't finished; the job keeps running in the background"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding FireAndForgetForAllActions}" VerticalAlignment="Center" OnContent="" OffContent=""/>
            </Grid>
        </Border>

        <!-- Master "expose predefined parameter sets" toggle -->
        <Border Grid.Row="5" Padding="10" Margin="0,0,0,8" BorderThickness="1" CornerRadius="4" BorderBrush="#2DD4BF">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="Expose predefined parameter sets"/>
                    <TextBlock FontSize="11" Foreground="#858585" TextWrapping="Wrap" Text="When on, each action's predefined parameter sets are exposed as additional MCP tools, inheriting the action's settings. Use the per-action toggle to opt individual actions in when this is off."/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding ExposePredefinedParameterSets}" VerticalAlignment="Center" OnContent="" OffContent=""/>
            </Grid>
        </Border>

        <!-- Per-action grid -->
        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="#858585" Margin="0,0,0,4"
                       Text="Individual actions:"/>

            <TextBox Grid.Row="1"
                     Text="{Binding ActionFilter}"
                     Watermark="Search actions..."
                     Margin="0,0,0,6"
                     Padding="10,6"
                     BorderThickness="1"
                     BorderBrush="#3f3f46"
                     Background="#252526"/>

            <!-- Column headers -->
            <Grid Grid.Row="2" Margin="8,0,8,2" ColumnDefinitions="*,90,110,100,110,100">
                <TextBlock Grid.Column="0" FontSize="11" Foreground="#666" Text="Action"/>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#60A5FA" HorizontalAlignment="Center" Text="Exposed"/>
                <TextBlock Grid.Column="2" FontSize="11" Foreground="#C084FC" HorizontalAlignment="Center" Text="Return output"/>
                <TextBlock Grid.Column="3" FontSize="11" Foreground="#FF8C00" HorizontalAlignment="Center" Text="Brave mode"/>
                <TextBlock Grid.Column="4" FontSize="11" Foreground="#4CAF50" HorizontalAlignment="Center" Text="Fire &amp; forget"/>
                <TextBlock Grid.Column="5" FontSize="11" Foreground="#2DD4BF" HorizontalAlignment="Center" Text="Param sets"/>
            </Grid>

            <Border Grid.Row="3" BorderThickness="1" BorderBrush="#333" CornerRadius="4">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding FilteredAvailableActions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:McpActionToggleViewModel">
                                <Grid Margin="8,2" ColumnDefinitions="*,90,110,100,110,100">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding DisplayName}"
                                               Foreground="#CCCCCC"/>
                                     <ToggleSwitch Grid.Column="1"
                                                   IsChecked="{Binding IsEnabled}"
                                                   IsEnabled="{Binding DataContext.CanConfigureIndividualActions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   OnContent="" OffContent=""
                                                   Margin="0,0,0,0"/>
                                     <ToggleSwitch Grid.Column="2"
                                                   IsChecked="{Binding ExposeOutput}"
                                                   IsEnabled="{Binding CanEditExposeOutput}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   OnContent="" OffContent=""
                                                   Margin="0,0,0,0"/>
                                      <ToggleSwitch Grid.Column="3"
                                                    IsChecked="{Binding BraveMode}"
                                                    IsEnabled="{Binding CanEditBraveMode}"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    OnContent="" OffContent=""
                                                   Margin="0,0,0,0"/>
                                     <ToggleSwitch Grid.Column="4"
                                                   IsChecked="{Binding FireAndForget}"
                                                   IsEnabled="{Binding CanEditFireAndForget}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   OnContent="" OffContent=""
                                                   Margin="0,0,0,0"/>
                                     <ToggleSwitch Grid.Column="5"
                                                   IsChecked="{Binding IncludePredefinedSets}"
                                                   IsEnabled="{Binding CanEditIncludePredefinedSets}"
                                                   IsVisible="{Binding HasPredefinedSets}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   OnContent="" OffContent=""
                                                   Margin="0,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Save button -->
        <Button Grid.Row="7"
                HorizontalAlignment="Right"
                Width="140"
                HorizontalContentAlignment="Center"
                Click="OnSaveClicked">
            Save &amp; Apply
        </Button>
    </Grid>
</Window>
