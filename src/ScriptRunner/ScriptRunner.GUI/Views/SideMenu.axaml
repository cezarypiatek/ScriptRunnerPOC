<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
             xmlns:viewModels="clr-namespace:ScriptRunner.GUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:MainWindowViewModel"
             x:Class="ScriptRunner.GUI.Views.SideMenu">
<Border BorderThickness="0,0,2,0" BorderBrush="#FF3E3E40">
    <StackPanel Orientation="Vertical"  >
        <StackPanel.Styles>
            <Style Selector=":is(Button)">
                <Setter Property="Margin" Value="5"></Setter>
                <Setter Property="Width" Value="50"></Setter>
                <Setter Property="Height" Value="35"></Setter>
                <Setter Property="FontSize" Value="18"></Setter>
                <Setter Property="Background" Value="Transparent"></Setter>
                <Setter Property="Foreground" Value="#858585"></Setter>
            </Style>
            <Style Selector="Button:hover">
                <Setter Property="Foreground" Value="#FFFFFF"></Setter>
            </Style>
        </StackPanel.Styles>
        <ToggleButton i:Attached.Icon="fas fa-scroll" IsChecked="{Binding IsScriptListVisible}"  ToolTip.Tip="Script list"/>
        <ToggleButton i:Attached.Icon="fas fa-clock" IsChecked="{Binding IsRecentListVisible}"  ToolTip.Tip="Recently executed"/>
        <ToggleButton i:Attached.Icon="fas fa-chart-bar" IsChecked="{Binding IsStatisticsVisible}"  ToolTip.Tip="Statistics"/>
        <Button i:Attached.Icon="fas fa-cog" Command="{Binding OpenSettingsWindow}"   ToolTip.Tip="Configure actions sources"/>
        <Button Command="{Binding OpenMcpConfigWindow}" ToolTip.Tip="MCP Server" Margin="5" Width="50" Height="35">
            <Grid>
                <Viewbox Width="20" Height="20" Stretch="Uniform">
                    <Canvas Width="24" Height="24">
                        <Path Fill="{Binding $parent[Button].Foreground}"
                              Stroke="{Binding $parent[Button].Foreground}"
                              StrokeThickness="1"
                              Data="m19.97,11.84c.66-.66,1.02-1.53,1.02-2.46s-.36-1.8-1.02-2.46l-.04-.04c-.66-.66-1.53-1.02-2.46-1.02-.17,0-.34.03-.51.05.02-.17.05-.33.05-.51,0-.93-.36-1.8-1.02-2.46-.66-.66-1.53-1.02-2.46-1.02s-1.8.36-2.46,1.02l-7.87,7.87c-.27.27-.27.71,0,.98s.71.27.98,0l7.87-7.87c.39-.39.92-.61,1.47-.61s1.08.22,1.47.61c.39.39.61.92.61,1.48s-.22,1.08-.61,1.48l-5.86,5.86-.08.08c-.27.27-.27.71,0-.98.14.14.31.2.49.2s.36-.07.49-.2l5.94-5.94c.39-.39.92-.61,1.48-.61s1.08.22,1.47.61l.04.04c.39.39.61.92.61,1.47s-.22,1.08-.61,1.48l-7.11,7.11c-.63.63-.63,1.66,0,2.29l1.46,1.46c.14.14.31.2.49.2s.36-.07.49-.2c.27-.27.27-.71,0-.98l-1.46-1.46c-.09-.09-.09-.24,0-.33l7.11-7.11Z M17.96,9.83c.27-.27.27-.71,0-.98-.27-.27-.71-.27-.98,0l-5.82,5.82c-.81.81-2.14.81-2.95,0-.81-.81-.81-2.14,0-2.95l5.82-5.82c.27-.27.27-.71,0-.98-.27-.27-.71-.27-.98,0l-5.82,5.82c-1.36,1.36-1.36,3.56,0,4.92.68.68,1.57,1.02,2.46,1.02s1.78-.34,2.46-1.02l5.82-5.82Z"/>
                    </Canvas>
                </Viewbox>
                <Ellipse Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2" Fill="Green" IsVisible="{Binding IsMcpRunning}"/>
                <Ellipse Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2" Fill="Red" IsVisible="{Binding !IsMcpRunning}"/>
            </Grid>
        </Button>
        <Button Command="{Binding ForceRefresh}" ToolTip.Tip="Refresh actions" Margin="5" Width="50" Height="35">
            <Grid>
                <i:Icon Value="fas fa-sync" FontSize="18"/>
                <ProgressBar IsIndeterminate="True" 
                             IsVisible="{Binding IsAnyRefreshInProgress}"
                             Height="3" 
                             VerticalAlignment="Bottom"
                             ZIndex="1"
                             Margin="0,0,0,-5"/>
            </Grid>
        </Button>
        <Button i:Attached.Icon="fas fa-lock" Command="{Binding OpenVaultWindow}"   ToolTip.Tip="Open Vault" />
        <Button i:Attached.Icon="fas fa-search" Click="OpenSearchBox" HotKey="{Binding SearchBoxHotKey}"  ToolTip.Tip="Open Search Box (Ctrl+P)" />
    </StackPanel>
</Border>
</UserControl>
